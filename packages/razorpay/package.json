{
  "name": "@carbon/razorpay",
  "dependencies": {
    "@carbon/env": "workspace:*",
    "@carbon/utils": "workspace:*",
    "razorpay": "2.9.5",
    "zod": "catalog:"
  },
  "type": "module",
  "devDependencies": {
    "@carbon/config": "workspace:*",
    "@types/node": "20.19.39",
    "dotenv": "16.3.1",
    "rimraf": "catalog:",
    "sst": "catalog:",
    "tsup": "catalog:",
