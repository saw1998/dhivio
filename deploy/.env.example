# Single source of truth for prod. Lives at /srv/dhivio/.env on the VPS.
# Generated by deploy/scripts/bootstrap.sh — values marked [AUTO] are minted
# locally; values marked [USER] must be filled in by the operator.

# ────────────────────────────────────────────────────────────────
# [AUTO] Generated by bootstrap.sh — DO NOT edit unless rotating
# ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=
SESSION_SECRET=
SUPABASE_JWT_SECRET=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
REALTIME_SECRET_KEY_BASE=
REALTIME_DB_ENC_KEY=
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ────────────────────────────────────────────────────────────────
# [AUTO] Domain-derived
# ────────────────────────────────────────────────────────────────
DOMAIN=dhivio.com
ERP_URL=https://erp.dhivio.com
MES_URL=https://mes.dhivio.com
SUPABASE_URL=https://api.dhivio.com
REDIS_URL=redis://redis:6379/0
INNGEST_BASE_URL=http://inngest:8288
SUPABASE_AUTH_EXTERNAL_GOOGLE_REDIRECT_URI=https://api.dhivio.com/auth/v1/callback
SUPABASE_AUTH_EXTERNAL_AZURE_REDIRECT_URI=https://api.dhivio.com/auth/v1/callback

# Default image tag — deploy-app.sh overrides per release
IMAGE_TAG=latest

# Docker Hub namespace under which dhivio-erp / dhivio-mes images are pushed.
# Must match secrets.DOCKERHUB_USERNAME used by .github/workflows/build-and-push.yml.
DOCKERHUB_USERNAME=sachin4668

# ────────────────────────────────────────────────────────────────
# [AUTO] App defaults
# ────────────────────────────────────────────────────────────────
CARBON_EDITION=community
AUTH_PROVIDERS=email,google
RATE_LIMIT=5

# ────────────────────────────────────────────────────────────────
# [USER] OAuth (Google + Azure)
# ────────────────────────────────────────────────────────────────
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=
SUPABASE_AUTH_EXTERNAL_AZURE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_AZURE_CLIENT_SECRET=

# ────────────────────────────────────────────────────────────────
# [USER] SMTP (via Resend by default)
# ────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_ADMIN_EMAIL=admin@dhivio.com
SMTP_SENDER_NAME=Dhivio
RESEND_API_KEY=
RESEND_DOMAIN=dhivio.com

# ────────────────────────────────────────────────────────────────
# [USER] Payment
# ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ────────────────────────────────────────────────────────────────
# [USER] Notifications / Analytics / AI
# ────────────────────────────────────────────────────────────────
NOVU_APPLICATION_ID=
NOVU_SECRET_KEY=
POSTHOG_API_HOST=https://us.posthog.com
POSTHOG_PROJECT_PUBLIC_KEY=
CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=
SLACK_BOT_TOKEN=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_PLACES_API_KEY=
GTM_EVENTS_API_SECRET_KEY=

# ────────────────────────────────────────────────────────────────
# [USER] Misc
# ────────────────────────────────────────────────────────────────
# Set to your Let's Encrypt ACME server. Defaults to production.
# Staging (for testing, no rate-limit issues):
#   LETSENCRYPT_SERVER=https://acme-staging-v02.api.letsencrypt.org/directory
# (Add new secrets here. compose.apps.yml will pick them up via env_file.)
